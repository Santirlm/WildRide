<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block titulo %}Wild Ride{% endblock %}</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'tierra':   '#3D2B1F',
                        'bosque':   '#1D4E3A',
                        'bosque2':  '#153a2b',
                        'dorado':   '#C9A84C',
                        'dorado2':  '#a8873a',
                        'crema':    '#F5EFE0',
                        'fondo':    '#0a1f16',
                        'carta':    '#0f2d1e',
                        'borde':    '#1a4a2e',
                    },
                    fontFamily: {
                        'display': ['"Playfair Display"', 'serif'],
                        'sans':    ['"DM Sans"', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body { font-family: 'DM Sans', sans-serif; }

        /* Línea dorada animada en hover de nav links */
        .nav-link {
            position: relative;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -2px; left: 0;
            width: 0; height: 2px;
            background: #C9A84C;
            transition: width .25s ease;
        }
        .nav-link:hover::after { width: 100%; }

        /* Scrollbar personalizada */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0a1f16; }
        ::-webkit-scrollbar-thumb { background: #1D4E3A; border-radius: 3px; }

        /* Grain texture overlay */
        body::before {
            content: '';
            position: fixed; inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
            pointer-events: none; z-index: 999;
            opacity: .4;
        }
    </style>

    {% block estilos %}{% endblock %}
</head>

<body class="bg-fondo text-white min-h-screen flex flex-col">

    <!-- ══ NAVBAR ══ -->
    <nav class="bg-tierra/90 backdrop-blur border-b border-dorado/30 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">

            <!-- Logo -->
            <a href="/" class="flex items-center gap-3 group">
                <div class="w-10 h-10 rounded-full bg-bosque border-2 border-dorado flex items-center justify-center">
                    <span class="text-dorado font-black text-sm">WR</span>
                </div>
                <span class="font-display text-2xl font-black tracking-tight italic text-white group-hover:text-dorado transition-colors">
                    Wild<span class="text-dorado">Ride</span>
                </span>
            </a>

            <!-- Links -->
            <div class="hidden md:flex items-center gap-8 text-sm font-medium uppercase tracking-widest text-crema/70">
                <a href="/caballos" class="nav-link hover:text-crema transition-colors {% if paginaActual == 'caballos' %}text-dorado{% endif %}">
                    <i class="bi bi-trophy mr-1"></i>Caballos
                </a>
                <a href="/cuenta" class="ml-2 bg-bosque border border-dorado/50 text-dorado px-5 py-2 rounded-lg font-semibold hover:bg-dorado hover:text-tierra transition-all">
                    <i class="bi bi-person-circle mr-1"></i>Mi Cuenta
                </a>
            </div>

            <!-- Hamburger mobile -->
            <button class="md:hidden text-crema text-xl" onclick="document.getElementById('menu-mobile').classList.toggle('hidden')">
                <i class="bi bi-list"></i>
            </button>
        </div>

        <!-- Mobile menu -->
        <div id="menu-mobile" class="hidden md:hidden bg-tierra border-t border-dorado/20 px-4 py-4 space-y-3 text-sm font-medium uppercase tracking-wider">
            <a href="/caballos" class="block text-crema/70 hover:text-dorado transition">Caballos</a>
            <a href="/resultados" class="block text-crema/70 hover:text-dorado transition">Resultados</a>
            <a href="/carreras" class="block text-crema/70 hover:text-dorado transition">Carreras</a>
            <a href="/cuenta" class="block text-dorado">Mi Cuenta</a>
        </div>
    </nav>

    <!-- ══ CONTENIDO ══ -->
    <main class="flex-1">
        {% block contenido %}{% endblock %}
    </main>

    <!-- ══ FOOTER ══ -->
    <footer class="bg-tierra/60 border-t border-dorado/20 mt-16">
        <div class="max-w-7xl mx-auto px-4 py-8 flex flex-col md:flex-row justify-between items-center gap-4 text-crema/40 text-xs">
            <span class="font-display italic text-lg text-dorado/70">WildRide</span>
            <p>© 2025 WildRide · Apuestas responsables · Solo mayores de 18 años</p>
            <div class="flex gap-4">
                <a href="#" class="hover:text-crema transition">Privacidad</a>
                <a href="#" class="hover:text-crema transition">Términos</a>
                <a href="#" class="hover:text-crema transition">Contacto</a>
            </div>
        </div>
    </footer>

</body>
</html>
