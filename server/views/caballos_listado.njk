{% extends "base.njk" %}

{% block titulo %}Caballos | Wild Ride{% endblock %}

{% block estilos %}
<style>
    /* Card hover lift */
    .card-caballo {
        transition: transform .25s ease, box-shadow .25s ease;
    }
    .card-caballo:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(0,0,0,.5), 0 0 0 1px rgba(201,168,76,.25);
    }

    /* Imagen zoom suave */
    .card-img { transition: transform .5s ease; }
    .card-caballo:hover .card-img { transform: scale(1.07); }

    /* Badge de sexo */
    .badge-yegua    { background: #7c3d7c22; color: #d88fe0; border: 1px solid #7c3d7c55; }
    .badge-semental { background: #1D4E3A33; color: #5dd99b; border: 1px solid #1D4E3A66; }
    .badge-capon    { background: #3d2b1f55; color: #d4a97a; border: 1px solid #3d2b1f88; }

    /* Animación de entrada de cards */
    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .card-caballo { animation: fadeUp .4s ease both; }
    .card-caballo:nth-child(1) { animation-delay: .05s; }
    .card-caballo:nth-child(2) { animation-delay: .10s; }
    .card-caballo:nth-child(3) { animation-delay: .15s; }
    .card-caballo:nth-child(4) { animation-delay: .20s; }
    .card-caballo:nth-child(5) { animation-delay: .25s; }
    .card-caballo:nth-child(6) { animation-delay: .30s; }

    /* Input / select focus */
    .filtro-input:focus {
        outline: none;
        border-color: #C9A84C;
        box-shadow: 0 0 0 3px rgba(201,168,76,.15);
    }

    /* Checkbox personalizado */
    input[type="checkbox"] { accent-color: #C9A84C; }
</style>
{% endblock %}

{% block contenido %}

<!-- ══ HERO BANNER ══ -->
<header class="relative h-56 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/30 to-fondo z-10"></div>
    <img
        src="https://images.unsplash.com/photo-1534445867742-43195f401b6c?auto=format&fit=crop&q=80&w=2000"
        class="w-full h-full object-cover object-center scale-105"
        alt="Carrera de caballos"
    >
    <div class="relative z-20 max-w-7xl mx-auto h-full flex flex-col justify-end px-6 pb-8">
        <p class="text-dorado text-xs font-bold uppercase tracking-widest mb-1">
            <i class="bi bi-broadcast-pin animate-pulse"></i> En Vivo · Gran Premio de Madrid
        </p>
        <h1 class="font-display text-5xl font-black italic text-white leading-none">
            El Catálogo
        </h1>
    </div>
</header>

<!-- ══ BREADCRUMB ══ -->
<div class="max-w-7xl mx-auto px-6 py-3 text-xs text-crema/30 flex items-center gap-2">
    <a href="/" class="hover:text-dorado transition">Inicio</a>
    <i class="bi bi-chevron-right text-[10px]"></i>
    <span class="text-dorado">Caballos</span>
</div>

<!-- ══ CUERPO PRINCIPAL ══ -->
<div class="max-w-7xl mx-auto px-6 pb-16 grid grid-cols-1 lg:grid-cols-[300px_1fr] gap-8">

    <!-- ────── SIDEBAR DE FILTROS ────── -->
    <aside class="lg:sticky lg:top-24 self-start bg-carta border border-borde rounded-2xl overflow-hidden h-fit">

        <div class="bg-bosque/40 border-b border-borde px-6 py-4 flex items-center gap-2">
            <i class="bi bi-sliders text-dorado"></i>
            <h2 class="font-display font-bold text-lg text-white">Filtros</h2>
        </div>

        <form action="/caballos" method="GET" class="p-6 space-y-7">

            <!-- Buscador -->
            <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-crema/40 mb-2">Buscar</label>
                <div class="relative">
                    <input
                        type="text"
                        name="nombre"
                        value="{{ filtros.nombre }}"
                        placeholder="Nombre del caballo..."
                        class="filtro-input w-full bg-fondo border border-borde rounded-lg px-4 py-2.5 pr-10 text-sm text-crema placeholder-crema/25 transition-all"
                    >
                    <i class="bi bi-search absolute right-3 top-3 text-crema/30 text-sm"></i>
                </div>
            </div>

            <!-- Filtro: Sexo -->
            <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-crema/40 mb-3">Sexo</label>
                <div class="space-y-2 text-sm">
                    {% for opcion in ['yegua', 'semental', 'capón'] %}
                    <label class="flex items-center gap-3 cursor-pointer group">
                        <input
                            type="checkbox"
                            name="sexo"
                            value="{{ opcion }}"
                            class="w-4 h-4 rounded"
                            {% if opcion in filtros.sexo %}checked{% endif %}
                        >
                        <span class="text-crema/70 group-hover:text-crema transition capitalize">{{ opcion }}</span>
                    </label>
                    {% endfor %}
                </div>
            </div>

            <!-- Filtro: Edad -->
            <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-crema/40 mb-3">Edad</label>
                <div class="space-y-2 text-sm">
                    <label class="flex items-center gap-3 cursor-pointer group">
                        <input type="checkbox" name="edad" value="2-3" class="w-4 h-4 rounded" {% if '2-3' in filtros.edad %}checked{% endif %}>
                        <span class="text-crema/70 group-hover:text-crema transition">2 – 3 años</span>
                    </label>
                    <label class="flex items-center gap-3 cursor-pointer group">
                        <input type="checkbox" name="edad" value="4-5" class="w-4 h-4 rounded" {% if '4-5' in filtros.edad %}checked{% endif %}>
                        <span class="text-crema/70 group-hover:text-crema transition">4 – 5 años</span>
                    </label>
                    <label class="flex items-center gap-3 cursor-pointer group">
                        <input type="checkbox" name="edad" value="6+" class="w-4 h-4 rounded" {% if '6+' in filtros.edad %}checked{% endif %}>
                        <span class="text-crema/70 group-hover:text-crema transition">6+ años</span>
                    </label>
                </div>
            </div>

            <!-- Filtro: Premio mínimo -->
            <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-crema/40 mb-2">Premio mín. (€)</label>
                <input
                    type="number"
                    name="premioMin"
                    value="{{ filtros.premioMin }}"
                    placeholder="0"
                    min="0"
                    class="filtro-input w-full bg-fondo border border-borde rounded-lg px-4 py-2.5 text-sm text-crema placeholder-crema/25 transition-all"
                >
            </div>

            <!-- Ordenar -->
            <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-crema/40 mb-2">Ordenar por</label>
                <select
                    name="orden"
                    class="filtro-input w-full bg-fondo border border-borde rounded-lg px-4 py-2.5 text-sm text-crema transition-all"
                >
                    <option value="nombre"       {% if filtros.orden == 'nombre' %}selected{% endif %}>Nombre (A–Z)</option>
                    <option value="premio_asc"   {% if filtros.orden == 'premio_asc' %}selected{% endif %}>Premio (menor primero)</option>
                    <option value="premio_desc"  {% if filtros.orden == 'premio_desc' %}selected{% endif %}>Premio (mayor primero)</option>
                    <option value="edad_asc"     {% if filtros.orden == 'edad_asc' %}selected{% endif %}>Edad (menor a mayor)</option>
                </select>
            </div>

            <!-- Botones -->
            <div class="space-y-2 pt-1">
                <button
                    type="submit"
                    class="w-full bg-dorado hover:bg-dorado2 text-tierra font-bold py-3 rounded-xl transition-all uppercase tracking-widest text-xs shadow-lg active:scale-95"
                >
                    <i class="bi bi-funnel-fill mr-1"></i> Aplicar filtros
                </button>
                <a
                    href="/caballos"
                    class="block text-center w-full border border-borde hover:border-dorado/50 text-crema/40 hover:text-crema/70 font-medium py-2.5 rounded-xl transition-all text-xs uppercase tracking-widest"
                >
                    Limpiar todo
                </a>
            </div>

        </form>
    </aside>

    <!-- ────── LISTADO DE CABALLOS ────── -->
    <section>

        <!-- Cabecera resultados -->
        <div class="flex items-center justify-between mb-6">
            <h2 class="font-display text-2xl font-bold text-white">
                Participantes
                <span class="ml-2 text-sm font-sans font-normal text-crema/30">({{ caballos | length }} encontrados)</span>
            </h2>
        </div>

        <!-- Cards -->
        {% if caballos | length > 0 %}
        <div class="space-y-4">
            {% for caballo in caballos %}
            <article class="card-caballo bg-carta border border-borde rounded-2xl overflow-hidden">
                <div class="flex flex-col sm:flex-row">

                    <!-- Imagen -->
                    <div class="sm:w-48 h-44 sm:h-auto flex-shrink-0 overflow-hidden relative">
                        {% if caballo.imagen %}
                            <img
                                src="{{ caballo.imagen }}"
                                alt="{{ caballo.nombre }}"
                                class="card-img w-full h-full object-cover"
                            >
                        {% else %}
                            <div class="w-full h-full bg-bosque/30 flex items-center justify-center">
                                <i class="bi bi-image text-4xl text-borde"></i>
                            </div>
                        {% endif %}
                        
                    </div>

                    <!-- Info -->
                    <div class="flex-1 p-5 flex flex-col justify-between">
                        <div>
                            <div class="flex items-start justify-between gap-3 flex-wrap">
                                <div>
                                    <h3 class="font-display text-2xl font-black italic text-white uppercase leading-tight">
                                        {{ caballo.nombre }}
                                    </h3>
                                    <p class="text-crema/40 text-xs mt-0.5">
                                        <i class="bi bi-person-fill mr-1"></i>Jinete: <span class="text-crema/60">{{ caballo.jinete }}</span>
                                    </p>
                                </div>

                                <!-- Badge sexo -->
                                <span class="text-xs font-bold px-3 py-1 rounded-full capitalize
                                    {% if caballo.sexo == 'yegua' %}badge-yegua
                                    {% elif caballo.sexo == 'semental' %}badge-semental
                                    {% else %}badge-capon{% endif %}">
                                    {{ caballo.sexo }}
                                </span>
                            </div>

                            <!-- Descripción -->
                            {% if caballo.descripcion %}
                            <p class="text-crema/40 text-sm mt-3 leading-relaxed line-clamp-2">{{ caballo.descripcion }}</p>
                            {% endif %}
                        </div>

                        <!-- Meta info + CTA -->
                        <div class="flex items-end justify-between mt-4 pt-4 border-t border-borde flex-wrap gap-3">

                            <!-- Stats -->
                            <div class="flex gap-5 text-xs text-crema/40 uppercase tracking-wider font-semibold">
                                <div>
                                    <span class="block text-crema/20 mb-0.5">Raza</span>
                                    <span class="text-crema/70">{{ caballo.raza }}</span>
                                </div>
                                <div>
                                    <span class="block text-crema/20 mb-0.5">Edad</span>
                                    <span class="text-crema/70">{{ caballo.edad }} años</span>
                                </div>
                                <div>
                                    <span class="block text-crema/20 mb-0.5">Premio</span>
                                    <span class="text-dorado font-bold">{{ caballo.premio }}€</span>
                                </div>
                            </div>

                            <!-- Botón apostar -->
                            <a
                                href="/caballos/{{ caballo._id }}"
                                class="bg-bosque hover:bg-bosque2 border border-bosque2 hover:border-dorado/50 text-white hover:text-dorado font-bold px-6 py-2.5 rounded-xl transition-all text-sm active:scale-95"
                            >
                                Ver ficha <i class="bi bi-arrow-right ml-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </article>
            {% endfor %}
        </div>

        {% else %}
        <!-- Estado vacío -->
        <div class="flex flex-col items-center justify-center py-24 text-center">
            <i class="bi bi-search text-5xl text-borde mb-4"></i>
            <h3 class="font-display text-2xl font-bold text-crema/30 mb-2">Sin resultados</h3>
            <p class="text-crema/20 text-sm max-w-xs">No hay caballos que coincidan con los filtros aplicados. Prueba a ampliar la búsqueda.</p>
            <a href="/caballos" class="mt-6 text-dorado text-sm hover:underline">Limpiar filtros</a>
        </div>
        {% endif %}

    </section>
</div>

{% endblock %}
